generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  AGENCY_ADMIN
  AGENT
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  WEB_FORM
  PORTAL
  MANUAL_IMPORT
}

/** Estado de la conexión técnica con Meta (WhatsApp / Instagram). */
enum ChannelConnectionStatus {
  DISCONNECTED
  PENDING_SETUP
  CONNECTED
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  VISIT_SCHEDULED
  OFFER_NEGOTIATION
  WON
  LOST
  NURTURE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum SenderType {
  CONTACT
  AGENT
  SYSTEM
}

enum DeliveryStatus {
  NOT_SENT
  DELIVERED
  READ
  FAILED
}

enum MessageApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FinancingMode {
  CASH
  MORTGAGE
  PRE_APPROVED
  UNKNOWN
}

enum SeriousnessLevel {
  HIGH
  MEDIUM
  LOW
}

enum UrgencyLevel {
  HIGH
  MEDIUM
  LOW
}

enum LeadPriority {
  P1
  P2
  P3
}

enum TaskStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum TaskType {
  CALL
  FOLLOW_UP_MESSAGE
  VISIT_CONFIRM
  MANUAL_REVIEW
}

enum AiRunType {
  EXTRACT_PROFILE
  SCORE_LEAD
  RANK_PROPERTIES
  FOLLOW_UP_PLAN
}

enum AiRunStatus {
  SUCCESS
  FAILED
}

enum CriticalJobStatus {
  QUEUED
  RUNNING
  RETRY_SCHEDULED
  SUCCEEDED
  FAILED
}

enum FollowUpEventStatus {
  SCHEDULED
  EXECUTED
  FAILED
  NEEDS_APPROVAL
}

enum RecommendationUseCase {
  LIVING
  INVESTMENT
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("UTC")
  aiUrgencyThreshold Int @default(75)
  aiMatchingMode String  @default("CONSERVADOR")
  aiOutreachTone String  @default("Sofisticado y reservado")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  channelConnections ChannelConnection[]
  leads            Lead[]
  properties       Property[]
  aiRuns           AiRun[]
  analyticsEvents  AnalyticsEvent[]
  auditLogs        AuditLog[]
  criticalJobs     CriticalJob[]
  subscription     AgencySubscription?
}

model User {
  id          String    @id @default(cuid())
  agencyId    String    @default("agency_demo_001")
  email       String
  name        String
  emailVerified Boolean @default(false)
  image       String?
  role        UserRole  @default(AGENT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agency      Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  ownedLeads  Lead[]    @relation("LeadOwner")
  sessions    Session[]
  accounts    Account[]
  auditLogs   AuditLog[]

  @@unique([agencyId, email])
  @@unique([email])
  @@index([agencyId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model ChannelConnection {
  id                String                   @id @default(cuid())
  agencyId          String
  type              ChannelType
  label             String
  /** ID en Meta: phone_number_id (WhatsApp) o Instagram user/page id según el producto. */
  externalAccountId String?
  status            ChannelConnectionStatus  @default(PENDING_SETUP)
  /** Detalle de errores, tokens opacos, ids secundarios (p. ej. WABA id). No guardar secretos en claro en producción. */
  metadata          Json?
  /** Token de acceso de Meta (Graph API) cifrado con AES-256-GCM (ver META_TOKEN_ENCRYPTION_KEY). */
  accessTokenEnc    String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  agency            Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  conversations     Conversation[]

  @@index([agencyId, type])
  @@index([externalAccountId])
}

model Lead {
  id                String            @id @default(cuid())
  agencyId          String
  contactName       String?
  ownerUserId       String?
  stage             LeadStage         @default(NEW)
  sourceChannel     ChannelType
  sourceCampaign    String?
  leadScore         Int               @default(0)
  closeProbability  Int               @default(0)
  priority          LeadPriority      @default(P3)
  timelineMonths    Int?
  seriousness       SeriousnessLevel  @default(LOW)
  urgency           UrgencyLevel      @default(LOW)
  lastActivityAt    DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  agency            Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  owner             User?             @relation("LeadOwner", fields: [ownerUserId], references: [id])
  profile           LeadProfile?
  conversations     Conversation[]
  notes             Note[]
  tasks             Task[]
  followUpEvents    FollowUpEvent[]
  recommendations   PropertyRecommendation[]
  stageHistory      LeadStageHistory[]
  aiRuns            AiRun[]
  analyticsEvents   AnalyticsEvent[]

  @@index([agencyId, stage])
  @@index([agencyId, priority])
  @@index([agencyId, lastActivityAt])
}

model LeadProfile {
  id                  String           @id @default(cuid())
  leadId              String           @unique
  budgetMin           Int?
  budgetMax           Int?
  budgetCurrency      String?
  preferredZones      String[]
  propertyType        String
  bedrooms            Int?
  financingMode       FinancingMode    @default(UNKNOWN)
  timelineMonths      Int?
  seriousness         SeriousnessLevel
  urgency             UrgencyLevel
  objections          String[]
  buyingIntentSummary String
  extractionJson      Json
  confidenceOverall   Float
  updatedAt           DateTime         @updatedAt

  lead                Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Conversation {
  id                  String            @id @default(cuid())
  leadId              String
  agencyId            String
  channelConnectionId String?
  externalThreadId    String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  lead                Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channelConnection   ChannelConnection? @relation(fields: [channelConnectionId], references: [id], onDelete: SetNull)
  messages            Message[]

  @@index([leadId])
  @@index([agencyId])
}

model Message {
  id                 String           @id @default(cuid())
  conversationId     String
  agencyId           String
  /** ID externo del proveedor de mensajería (p. ej. wamid de Meta). */
  externalMessageId  String?
  direction          MessageDirection
  senderType         SenderType
  senderName         String?
  body               String
  sentAt             DateTime
  approvalStatus     MessageApprovalStatus @default(APPROVED)
  deliveryStatus     DeliveryStatus
  createdAt          DateTime         @default(now())

  conversation       Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@index([conversationId, externalMessageId])
  @@index([agencyId, externalMessageId])
  @@index([agencyId, sentAt])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  body      String
  author    String
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model Task {
  id          String     @id @default(cuid())
  leadId       String
  type         TaskType
  status       TaskStatus @default(OPEN)
  title        String
  dueAt        DateTime?
  createdAt    DateTime   @default(now())

  lead         Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, status])
}

model FollowUpEvent {
  id          String              @id @default(cuid())
  leadId       String
  status       FollowUpEventStatus
  title        String
  detail       String
  scheduledFor DateTime
  occurredAt   DateTime?
  createdAt    DateTime            @default(now())

  lead         Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, scheduledFor])
}

model Property {
  id               String      @id @default(cuid())
  agencyId         String
  title            String
  neighborhood     String
  price            Int
  currency         String      @default("USD")
  bedrooms         Int
  bathrooms        Int
  propertyType     String
  useCase          RecommendationUseCase
  appreciationNote String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  agency           Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  recommendations  PropertyRecommendation[]

  @@index([agencyId, neighborhood])
  @@index([agencyId, useCase])
}

model PropertyRecommendation {
  id            String    @id @default(cuid())
  leadId         String
  propertyId     String
  rank           Int
  fitScore       Float
  reasons        String[]
  tradeoff       String?
  strategy       String
  createdAt      DateTime @default(now())

  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([leadId, rank])
}

model LeadStageHistory {
  id         String    @id @default(cuid())
  leadId      String
  fromStage   LeadStage?
  toStage     LeadStage
  reason      String?
  changedAt   DateTime  @default(now())

  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, changedAt])
}

model AiRun {
  id            String      @id @default(cuid())
  agencyId      String
  leadId        String?
  type          AiRunType
  status        AiRunStatus
  model         String
  version       String
  inputHash     String
  outputJson    Json
  confidence    Float?
  createdAt     DateTime    @default(now())

  agency        Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  lead          Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([leadId, createdAt])
}

model AnalyticsEvent {
  id             String    @id @default(cuid())
  agencyId       String
  leadId         String?
  type           String
  properties     Json
  occurredAt     DateTime  @default(now())
  idempotencyKey String

  agency         Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  lead           Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@unique([agencyId, idempotencyKey])
  @@index([agencyId, occurredAt])
  @@index([leadId, occurredAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  agencyId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  summary    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([agencyId, resource, createdAt])
}

model CriticalJob {
  id             String            @id @default(cuid())
  agencyId       String
  type           String
  status         CriticalJobStatus @default(QUEUED)
  payload        Json
  idempotencyKey String
  attemptCount   Int               @default(0)
  maxAttempts    Int               @default(5)
  nextAttemptAt  DateTime          @default(now())
  lastRunAt      DateTime?
  lastError      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  agency         Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, idempotencyKey])
  @@index([agencyId, status, nextAttemptAt])
  @@index([agencyId, type, createdAt])
}

model AgencySubscription {
  id               String   @id @default(cuid())
  agencyId         String   @unique
  planCode         String   @default("starter")
  status           String   @default("trialing")
  seatLimit        Int      @default(3)
  monthlyPriceUsd  Int      @default(0)
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agency           Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}
